-- ====================
-- MINIMIZE FUNCTION
-- ====================
local isMinimized = false
local minimizedSize = UDim2.new(0, 260, 0, 35)
local expandedSize = UDim2.new(0, 260, 0, 160)

local function minimize()
    isMinimized = true
    contentFrame.Visible = false
    mainFrame:TweenSize(minimizedSize, Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
    minButton.Text = "+"
end

local function maximize()
    isMinimized = false
    contentFrame.Visible = true
    mainFrame:TweenSize(expandedSize, Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
    minButton.Text = "-"
end

minButton.MouseButton1Click:Connect(function()
    if isMinimized then
        maximize()
    else
        minimize()
    end
end)

-- ====================
-- FARM LOGIC
-- ====================
local isFarming = false
local farmThread = nil

local function findAllCandyEggs()
    local eggs = {}
    for _, obj in pairs(Workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "CandyEgg" then
            table.insert(eggs, obj)
        end
    end
    return eggs
end

local function teleportToEgg(egg)
    if not egg then return false end
    if not LocalPlayer.Character then return false end
    
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local targetPos = egg:GetPivot().Position
    hrp.CFrame = CFrame.new(targetPos.X, targetPos.Y + 3, targetPos.Z)
    return true
end

local function farmLoop()
    while isFarming do
        local eggs = findAllCandyEggs()
        local eggCount = #eggs
        
        countValue.Text = tostring(eggCount)
        
        if eggCount == 0 then
            task.wait(2)
        else
            for i, egg in pairs(eggs) do
                if not isFarming then break end
                
                currentValue.Text = i .. "/" .. eggCount
                teleportToEgg(egg)
                task.wait(0.2)
            end
            task.wait(0.5)
        end
    end
end

local function startFarming()
    if isFarming then return end
    
    if not LocalPlayer.Character then
        LocalPlayer.CharacterAdded:Wait()
    end
    
    isFarming = true
    checkboxFill.BackgroundTransparency = 0
    checkboxFill.BackgroundColor3 = Color3.fromRGB(120, 120, 130)
    
    task.spawn(farmLoop)
end

local function stopFarming()
    isFarming = false
    checkboxFill.BackgroundTransparency = 1
    currentValue.Text = "-"
    countValue.Text = "0"
end

-- Checkbox Click
local function toggleFarm()
    if isFarming then
        stopFarming()
    else
        startFarming()
    end
end

checkbox.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        toggleFarm()
    end
end)

toggleLabel.InputBegan:Connect(function(input)
