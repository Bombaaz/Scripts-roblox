-- ========== GETNIL ==========
local function GetNil(Name, DebugId)
    for _, Object in getnilinstances() do
        if Object.Name == Name and Object:GetDebugId() == DebugId then
            return Object
        end
    end
    return nil
end

-- ========== EVENT ==========
local function getShootEvent()
    local systemResources = ReplicatedStorage:FindFirstChild("SystemResources")
    if systemResources then
        local bufferCache = systemResources:FindFirstChild("BufferCache")
        if bufferCache then
            local requestAction = bufferCache:FindFirstChild("RequestActionSync")
            if requestAction and requestAction:IsA("RemoteEvent") then
                return requestAction
            end
        end
    end
    
    for _, child in ipairs(ReplicatedStorage:GetDescendants()) do
        if child:IsA("RemoteEvent") and (child.Name:find("Request") or child.Name:find("Action") or child.Name:find("Sync")) then
            return child
        end
    end
    
    return nil
end

-- ========== FIND TARGET (NUR HEAD) ==========
local function findTarget()
    if not SilentAimActive then return nil end
    if not Camera then return nil end
    
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local closestTarget = nil
    local closestDist = math.huge
    
    -- ALLE SPIELER
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health and humanoid.Health > 0 then
                
                -- NUR HEAD FÜR HEADSHOT!
                local targetPart = player.Character:FindFirstChild("Head")
                if not targetPart then
                    targetPart = player.Character:FindFirstChild("UpperTorso")
                end
                if not targetPart then
                    targetPart = player.Character:FindFirstChild("Torso")
                end
                if not targetPart then
                    targetPart = player.Character:FindFirstChild("HumanoidRootPart")
                end
                
                if targetPart then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                    
                    if onScreen then
                        local distToCrosshair = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                        
                        if distToCrosshair <= FOV then
                            if distToCrosshair < closestDist then
                                closestDist = distToCrosshair
                                closestTarget = {
                                    Player = player,
                                    Part = targetPart,
                                    Position = targetPart.Position,
                                    Humanoid = humanoid,
                                    IsHead = targetPart.Name == "Head"
                                }
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- FALLBACK: NPCs/Zombies
    if not closestTarget then
        local folders = {"Enemies", "enemies", "Zombies", "zombies", "Mobs", "mobs", "NPCs", "npcs"}
        
        for _, folderName in ipairs(folders) do
            local folder = workspace:FindFirstChild(folderName)
            if folder then
                for _, enemy in ipairs(folder:GetChildren()) do
                    if enemy:IsA("Model") then
                        local humanoid = enemy:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid.Health and humanoid.Health > 0 then
                            
                            local targetPart = enemy:FindFirstChild("Head")
                            if not targetPart then
                                targetPart = enemy:FindFirstChild("UpperTorso")
                            end
                            if not targetPart then
                                targetPart = enemy:FindFirstChild("Torso")
                            end
                            if not targetPart then
                                targetPart = enemy:FindFirstChild("HumanoidRootPart")
                            end
                            
                            if targetPart then
                                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                                
                                if onScreen then
                                    local distToCrosshair = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                                    
                                    if distToCrosshair <= FOV then
                                        if distToCrosshair < closestDist then
                                            closestDist = distToCrosshair
                                            closestTarget = {
                                                Enemy = enemy,
                                                Part = targetPart,
                                                Position = targetPart.Position,
                                                Humanoid = humanoid,
                                                IsHead = targetPart.Name == "Head"
                                            }
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- FALLBACK 2: ALLE MODELS MIT HUMANOD
    if not closestTarget then
        for _, enemy in ipairs(workspace:GetChildren()) do
            if enemy:IsA("Model") and enemy ~= LocalPlayer.Character then
                local humanoid = enemy:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health and humanoid.Health > 0 then
                    local name = enemy.Name:lower()
                    if name:find("zombie") or name:find("enemy") or name:find("mob") or name:find("npc") then
                        
                        local targetPart = enemy:FindFirstChild("Head")
                        if not targetPart then
                            targetPart = enemy:FindFirstChild("UpperTorso")
                        end
                        if not targetPart then
                            targetPart = enemy:FindFirstChild("Torso")
                        end
                        if not targetPart then
                            targetPart = enemy:FindFirstChild("HumanoidRootPart")
                        end
                        
                        if targetPart then
                            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                            
                            if onScreen then
                                local distToCrosshair = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                                
                                if distToCrosshair <= FOV then
                                    if distToCrosshair < closestDist then
                                        closestDist = distToCrosshair
                                        closestTarget = {
                                            Enemy = enemy,
                                            Part = targetPart,
                                            Position = targetPart.Position,
                                            Humanoid = humanoid,
                                            IsHead = targetPart.Name == "Head"
                                        }
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    return closestTarget
end

-- ========== SILENT SHOOT ==========
local function silentShoot()
    if not SilentAimActive then return end
    
    local target = findTarget()
    if not target then
        Status.Text = "🔍 No target"
        Status.TextColor3 = Color3.fromRGB(255, 200, 0)
        return
    end
    
    local event = getShootEvent()
    if not event then
        Status.Text = "❌ No Event"
        Status.TextColor3 = Color3.fromRGB(255, 0, 0)
        return
    end
    
    -- RICHTUNG ZUM TARGET (HEAD)
    local direction = (target.Part.Position - Camera.CFrame.Position).Unit
    local origin = Camera.CFrame.Position
    
    -- ARGS BAUEN (EXAKT WIE IN DEINEM CODE)
    local args = {
        {
            direction = direction,
            hitPosition = target.Part.Position,
            origin = origin,
            hitInstance = target.Part,
            hitHumanoid = target.Humanoid,
            IsHeadshot = true  -- IMMER TRUE!
        }
    }
    
    -- FEUER!
    local success = pcall(function()
        event:FireServer(unpack(args))
    end)
    
    if success then
        local name = target.Player and target.Player.Name or target.Enemy and target.Enemy.Name or "Enemy"
        Status.Text = "💀 " .. name
        Status.TextColor3 = Color3.fromRGB(255, 0, 0)
        print("🎯 HEADSHOT:", name)
    else
        Status.Text = "❌ Failed"
        Status.TextColor3 = Color3.fromRGB(255, 0, 0)
    end
end

