local function createTabButton(name, index)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 0, 45)
    button.Position = UDim2.new(0, 0, 0, (index-1) * 45 + 5)
    button.BackgroundColor3 = index == 1 and colors.bg3 or colors.bg2
    button.BorderSizePixel = 0
    button.Text = name
    button.TextColor3 = index == 1 and colors.accent or colors.text2
    button.Font = Enum.Font.GothamBold
    button.TextSize = 13
    button.Parent = TabContainer
    
    local activeIndicator = Instance.new("Frame")
    activeIndicator.Size = UDim2.new(0, 3, 0.7, 0)
    activeIndicator.Position = UDim2.new(0, 0, 0.15, 0)
    activeIndicator.BackgroundColor3 = colors.accent
    activeIndicator.BorderSizePixel = 0
    activeIndicator.Visible = index == 1
    activeIndicator.Parent = button
    
    local indicatorCorner = Instance.new("UICorner")
    indicatorCorner.CornerRadius = UDim.new(0, 2)
    indicatorCorner.Parent = activeIndicator
    
    -- Content Frame
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -140, 1, -50)
    frame.Position = UDim2.new(0, 135, 0, 45)
    frame.BackgroundColor3 = colors.bg
    frame.BorderSizePixel = 0
    frame.Visible = index == 1
    frame.Parent = MainFrame
    
    local scrollingFrame = Instance.new("ScrollingFrame")
    scrollingFrame.Size = UDim2.new(1, -20, 1, -20)
    scrollingFrame.Position = UDim2.new(0, 10, 0, 10)
    scrollingFrame.BackgroundTransparency = 1
    scrollingFrame.BorderSizePixel = 0
    scrollingFrame.ScrollBarThickness = 4
    scrollingFrame.ScrollBarImageColor3 = colors.accent
    scrollingFrame.ScrollBarImageTransparency = 0.5
    scrollingFrame.CanvasSize = UDim2.new(0, 0, 2.5, 0)
    scrollingFrame.Parent = frame
    
    TabButtons[name] = {button = button, indicator = activeIndicator}
    TabFrames[name] = scrollingFrame
    
    button.MouseEnter:Connect(function()
        if index ~= 1 or not frame.Visible then
            TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = colors.bg3}):Play()
        end
    end)
    
    button.MouseLeave:Connect(function()
        if index ~= 1 or not frame.Visible then
            TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = colors.bg2}):Play()
        end
    end)
    
    button.MouseButton1Click:Connect(function()
        for _, f in pairs(TabFrames) do
            f.Parent.Visible = false
        end
        frame.Visible = true
        
        for tabName, tabData in pairs(TabButtons) do
            TweenService:Create(tabData.button, TweenInfo.new(0.2), {BackgroundColor3 = colors.bg2}):Play()
            tabData.button.TextColor3 = colors.text2
            tabData.indicator.Visible = false
        end
        
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = colors.bg3}):Play()
        button.TextColor3 = colors.accent
        activeIndicator.Visible = true
    end)
end

for i, tab in ipairs(Tabs) do
    createTabButton(tab, i)
end

