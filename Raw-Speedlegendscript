local OrbGroup = Tabs.Main:AddLeftGroupbox('⚡ Speed Auto Farm')

OrbGroup:AddSlider('OrbDelay', {
    Text = 'Delay between batches (ms)',
    Default = 10,
    Min = 5,
    Max = 100,
    Rounding = 0,
})

local OrbToggle = OrbGroup:AddToggle('OrbFarm', { Text = 'Auto Farm Orbs (ALL Locations)', Default = false })
local OrbStatus = OrbGroup:AddLabel('Status: OFF')
local OrbCountLabel = OrbGroup:AddLabel('Orbs collected: 0')
local OrbsPerSecLabel = OrbGroup:AddLabel('Orbs/sec: 0')

-- Locations
local locations = {
    "City",
    "Magma City",
    "Snow City",
    "Mysterious Cave",
    "Speed Jungle",
    "Inferno Cave"
}

local orbActive = false
local orbThread = nil
local orbCount = 0
local lastTime = tick()
local orbsPerSec = 0
local currentDelay = 10

local function ExecuteBatch()
    for _, location in pairs(locations) do
        pcall(function()
            local argsOrange = { "collectOrb", "Orange Orb", location }
            game:GetService("ReplicatedStorage"):WaitForChild("rEvents"):WaitForChild("orbEvent"):FireServer(unpack(argsOrange))
            
            local argsBlue = { "collectOrb", "Blue Orb", location }
            game:GetService("ReplicatedStorage"):WaitForChild("rEvents"):WaitForChild("orbEvent"):FireServer(unpack(argsBlue))
        end)
    end
    orbCount = orbCount + (2 * #locations)
end

local function StartOrb()
    if orbActive then return end
    orbActive = true
    orbCount = 0
    lastTime = tick()
    orbsPerSec = 0
    OrbCountLabel:SetText('Orbs collected: 0')
    OrbsPerSecLabel:SetText('Orbs/sec: 0')
    OrbStatus:SetText('Status: FARMING...')
    
    orbThread = task.spawn(function()
        while orbActive do
            currentDelay = Options.OrbDelay.Value
            ExecuteBatch()
            OrbCountLabel:SetText('Orbs collected: ' .. orbCount)
            
            local now = tick()
            if now - lastTime >= 1 then
                orbsPerSec = orbCount / (now - lastTime)
                OrbsPerSecLabel:SetText(string.format('Orbs/sec: %.0f', orbsPerSec))
                lastTime = now
                orbCount = 0
            end
            
            task.wait(currentDelay / 1000)
        end
    end)
end

local function StopOrb()
    orbActive = false
    if orbThread then task.cancel(orbThread) end
    OrbStatus:SetText('Status: OFF')
    OrbsPerSecLabel:SetText('Orbs/sec: 0')
end

OrbToggle:OnChanged(function()
    if OrbToggle.Value then StartOrb() else StopOrb() end
end)

